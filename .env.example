# Thames Water credentials (the same login you use at myaccount.thameswater.co.uk)
THAMESWATER_EMAIL=you@example.com
THAMESWATER_PASSWORD=your-password
THAMESWATER_ACCOUNT_NUMBER=123456789
THAMESWATER_METER=123456789

# Push remote_write data directly to Mimir's distributor.
THAMESWATER_EXPORTER_REMOTE_WRITE_URL=http://mimir:9009/api/v1/push
THAMESWATER_EXPORTER_MIMIR_TENANT=anonymous

# How much history to backfill on first run (no state yet), then it keeps up hourly.
# Thames Water only keeps HOURLY data for the last ~7 days, so values above 7 are
# clamped to 7 (older hourly data simply doesn't exist).
THAMESWATER_EXPORTER_BACKFILL_DAYS=7

# Days of hourly data fetched per request (the 7-day window fits in one request;
# this mainly matters if you fetch coarser/longer data in future).
THAMESWATER_EXPORTER_CHUNK_DAYS=7

# Pause between successive backfill requests, to be gentle on the API.
THAMESWATER_EXPORTER_CHUNK_DELAY_SECONDS=1

# How often to poll Thames Water for newly finalised hours.
THAMESWATER_EXPORTER_POLL_INTERVAL_SECONDS=3600

# Where the high-water-mark is persisted between runs.
THAMESWATER_EXPORTER_STATE_FILE=/data/state.json

# Port for the exporter's own /healthz and /metrics endpoints.
THAMESWATER_EXPORTER_HEALTH_PORT=9100

# THAMESWATER_EXPORTER_LOG_LEVEL=INFO

# Optional static labels added to every series, e.g. "location=home,env=prod"
# THAMESWATER_EXPORTER_EXTRA_LABELS=

# --- Optional: auth on the remote_write endpoint ---
# THAMESWATER_EXPORTER_REMOTE_WRITE_USERNAME=
# THAMESWATER_EXPORTER_REMOTE_WRITE_PASSWORD=
# THAMESWATER_EXPORTER_REMOTE_WRITE_BEARER_TOKEN=
