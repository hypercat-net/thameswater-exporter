# Thames Water credentials (the same login you use at myaccount.thameswater.co.uk)
EMAIL=you@example.com
PASSWORD=your-password
ACCOUNT_NUMBER=123456789
METER=123456789

# Where to push remote_write data. Default targets the Alloy receiver in docker-compose.
REMOTE_WRITE_URL=http://alloy:9999/api/v1/metrics/write

# How much history to backfill on first run (no state yet), then it keeps up hourly.
# Thames Water only keeps HOURLY data for the last ~7 days, so values above 7 are
# clamped to 7 (older hourly data simply doesn't exist).
BACKFILL_DAYS=7

# Days of hourly data fetched per request (the 7-day window fits in one request;
# this mainly matters if you fetch coarser/longer data in future).
CHUNK_DAYS=7

# Pause between successive backfill requests, to be gentle on the API.
CHUNK_DELAY_SECONDS=1

# How often to poll Thames Water for newly finalised hours.
POLL_INTERVAL_SECONDS=3600

# Where the high-water-mark is persisted between runs.
STATE_FILE=/data/state.json

# Port for the exporter's own /healthz and /metrics endpoints.
HEALTH_PORT=9100

# LOG_LEVEL=INFO

# Optional static labels added to every series, e.g. "location=home,env=prod"
# EXTRA_LABELS=

# --- Optional: only needed if pushing somewhere that requires auth ---
# Alloy's prometheus.receive_http does NOT forward these to Mimir; set the
# tenant on Alloy's remote_write instead (see config/alloy/config.alloy).
# REMOTE_WRITE_USERNAME=
# REMOTE_WRITE_PASSWORD=
# REMOTE_WRITE_BEARER_TOKEN=
# MIMIR_TENANT=
